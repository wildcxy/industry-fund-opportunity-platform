APP_ENV=development
APP_PORT=8000
DATABASE_URL=postgresql://game_user:game_password@localhost:5432/game_data
ACTIVE_DATA_VERSION=latest
RUNTIME_LOG_DIR=E:\game\runtime\logs
RUNTIME_DATA_ARCHIVE_DIR=E:\game\runtime\data-archive
RUNTIME_DROPZONE_DIR=E:\game\runtime\manual-drop
DATA_COLLECTION_MODE=manual-drop
AKSHARE_ENABLE=false
AKSHARE_SLEEP_MIN_SECONDS=1.5
AKSHARE_SLEEP_MAX_SECONDS=3.0
AKSHARE_RETRY_COUNT=3
AKSHARE_RETRY_BACKOFF_SECONDS=2.5
AKSHARE_CHUNK_SIZE=8
AKSHARE_CHUNK_COOLDOWN_SECONDS=6.0
AKSHARE_HISTORY_LOOKBACK_DAYS=240
AKSHARE_FUND_UNIVERSE_PATH=E:\game\backend\templates\coverage\fund_universe.csv
JIN10_ENABLE=false
JIN10_API_BASE_URL=
JIN10_API_KEY=
JIN10_POLL_INTERVAL_SECONDS=300
JIN10_REQUEST_TIMEOUT_SECONDS=10
TUSHARE_ENABLE=false
TUSHARE_TOKEN=
TUSHARE_REQUEST_TIMEOUT_SECONDS=20
TUSHARE_RETRY_COUNT=3
TUSHARE_RETRY_BACKOFF_SECONDS=2.0
TUSHARE_MIN_INTERVAL_SECONDS=0.85
